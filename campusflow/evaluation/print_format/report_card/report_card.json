 "html": "<h2 style=\"text-align:center;\">Report Card</h2>\n\n<hr>\n\n<p><b>Student:</b> {{ frappe.get_doc(\"Student\", doc.student).student_name }}</p>\n<p><b>Course:</b> {{ doc.course }}</p>\n<p><b>Exam:</b> {{ doc.exam_name }}</p>\n\n<hr>\n\n<table style=\"width:100%; border:1px solid black; border-collapse: collapse;\">\n    <tr>\n        <th style=\"border:1px solid black;\">Subject</th>\n        <th style=\"border:1px solid black;\">Marks</th>\n        <th style=\"border:1px solid black;\">Max Marks</th>\n    </tr>\n\n    {% set total = 0 %}\n    {% set max_total = 0 %}\n\n    {% for row in doc.results %}\n    <tr>\n        <td style=\"border:1px solid black;\">{{ row.subject }}</td>\n        <td style=\"border:1px solid black;\">{{ row.marks }}</td>\n        <td style=\"border:1px solid black;\">{{ row.max_marks }}</td>\n    </tr>\n\n    {% set total = total + row.marks %}\n    {% set max_total = max_total + row.max_marks %}\n    {% endfor %}\n</table>\n\n<br>\n\n<h3>Total: {{ total }} / {{ max_total }}</h3>\n<p><b>Percentage:</b> {{ (total / max_total * 100) | round(2) }}%</p>\n\n<br><br>\n\n<p>Signature</p>",
