  "font_size": 14,
  "format_data": null,
  "html": "<h2 style=\"text-align:center;\">Library Slip</h2>\n\n<hr>\n\n<p><b>Transaction ID:</b> {{ doc.name }}</p>\n<p><b>Date:</b> {{ doc.date }}</p>\n<p><b>Type:</b> {{ doc.transaction_type }}</p>\n\n<hr>\n\n<p><b>Student:</b> {{ frappe.get_doc(\"Student\", doc.student).student_name }}</p>\n\n<hr>\n\n<h3>Books</h3>\n\n<table style=\"width:100%; border:1px solid black; border-collapse: collapse;\">\n    <tr>\n        <th style=\"border:1px solid black;\">Book Name</th>\n        <th style=\"border:1px solid black;\">Quantity</th>\n    </tr>\n\n    {% for row in doc.books %}\n    <tr>\n        <td style=\"border:1px solid black;\">{{ row.book_name }}</td>\n        <td style=\"border:1px solid black;\">{{ row.quantity }}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n<br><br>\n\n<p>Signature</p>",
