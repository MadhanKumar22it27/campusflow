 "client_script": "frappe.web_form.on('program', (field, value) => {\n    console.log(\"Program selected:\", value);\n\n    frappe.call({\n        method: \"campusflow.api.get_courses_by_program\",\n        args: { program: value },\n        callback: function(r) {\n            console.log(\"Courses:\", r.message);\n\n            let options = r.message || [];\n\n            frappe.web_form.set_df_property(\n                'course',\n                'options',\n                options.join(\"\\n\")\n            );\n\n            frappe.web_form.set_value('course', null);\n        }\n    });\n});",
